{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(*.ex)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/format-elixir.sh",
            "timeout": 30,
            "statusMessage": "Formatting Elixir..."
          },
          {
            "type": "command",
            "if": "Edit(*.exs)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/format-elixir.sh",
            "timeout": 30,
            "statusMessage": "Formatting Elixir..."
          },
          {
            "type": "command",
            "if": "Edit(*.ex)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/iron-law-verifier.sh",
            "timeout": 15,
            "statusMessage": "Verifying Iron Laws..."
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "if": "Write(*.ex)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/format-elixir.sh",
            "timeout": 30,
            "statusMessage": "Formatting Elixir..."
          },
          {
            "type": "command",
            "if": "Write(*.exs)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/format-elixir.sh",
            "timeout": 30,
            "statusMessage": "Formatting Elixir..."
          },
          {
            "type": "command",
            "if": "Write(*plan.md)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/plan-stop-reminder.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/block-dangerous-ops.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(*mix*)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/elixir-failure-hints.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/inject-iron-laws.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/setup-dirs.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
